{
  "name": "plucker",
  "productName": "Plucker",
  "version": "0.2.0",
  "description": "Download YouTube playlists as tagged MP3s",
  "packageManager": "pnpm@11.5.0",
  "main": "./out/main/index.js",
  "author": "Filiph Sandström",
  "homepage": "",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "test": "vitest run",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps && node scripts/fetch-binaries.mjs",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "node scripts/fetch-binaries.mjs --all && npm run build && electron-builder --mac --arm64 --x64 --config electron-builder.yml --publish never",
    "build:linux": "npm run build && electron-builder --linux",
    "fetch-binaries": "node scripts/fetch-binaries.mjs"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource/geist": "^5.2.9",
    "@fontsource/geist-mono": "^5.2.8",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "i18next": "^26.3.0",
    "lucide-react": "^1.17.0",
    "ms": "^2.1.3",
    "node-id3": "^0.2.9",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.7"
  }
}
