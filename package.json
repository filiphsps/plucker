{
  "name": "plucker",
  "productName": "Plucker",
  "version": "0.15.1",
  "description": "Download YouTube playlists as tagged MP3s",
  "packageManager": "pnpm@11.5.0",
  "main": "./out/main/index.js",
  "author": {
    "name": "Filiph Sandström",
    "email": "filfat@hotmail.se",
    "url": "https://github.com/filiphsps"
  },
  "contributors": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/filiphsps/plucker.git"
  },
  "homepage": "https://github.com/filiphsps/plucker",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev --watch",
    "test": "vitest run",
    "build:icon": "node scripts/build-icon.mjs",
    "dev:icon": "node scripts/build-icon.mjs --watch",
    "build:screenshots": "node scripts/build-screenshots.mjs",
    "build": "pnpm run build:icon && pnpm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps && node scripts/fetch-binaries.mjs",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:win": "pnpm run build && electron-builder --win",
    "build:mac": "node scripts/fetch-binaries.mjs --all && pnpm run build && electron-builder --mac --arm64 --x64 --config electron-builder.yml --publish never",
    "build:linux": "pnpm run build && electron-builder --linux",
    "fetch-binaries": "node scripts/fetch-binaries.mjs"
  },
  "dependencies": {
    "@electron-toolkit/preload": "3.0.2",
    "@electron-toolkit/utils": "4.0.0",
    "@fontsource/geist": "5.2.9",
    "@fontsource/geist-mono": "5.2.8",
    "@vscode/sudo-prompt": "9.3.2",
    "electron-updater": "6.8.3",
    "essentia.js": "0.1.3",
    "ffmpeg-static": "5.3.0",
    "i18next": "26.3.0",
    "lucide-react": "1.17.0",
    "ms": "2.1.3",
    "node-id3": "0.2.9",
    "react-i18next": "17.0.8"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "3.1.0",
    "@electron-toolkit/tsconfig": "2.0.0",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "electron": "42.3.0",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "eslint": "9.39.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "playwright": "1.60.0",
    "prettier": "3.8.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.7"
  }
}
